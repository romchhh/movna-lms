# Optimate CRM
PUBLIC_BASE_URL=https://api.optimate.online
BASE_URL=https://movna.api.optimate.online
OPTIMATE_PUBLIC_API_KEY=
OPTIMATE_TOKEN=
# false — для локальних seed-акаунтів без Optimate; true — для prod
OPTIMATE_VERIFY_ON_LOGIN=true
OPTIMATE_CACHE_BALANCES_TTL=600
OPTIMATE_CACHE_TRANSACTIONS_TTL=600
OPTIMATE_CACHE_EVENTS_TTL=300
OPTIMATE_CACHE_ADMIN_LIST_TTL=300
OPTIMATE_CACHE_ADMIN_DETAIL_TTL=600
OPTIMATE_CACHE_ADMIN_EVENTS_TTL=300
OPTIMATE_CACHE_ADMIN_OVERVIEW_TTL=180

# Google OAuth (redirect URI має бути в Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

GOOGLE_SHEETS_CREDENTIALS_JSON=
